// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Step: 1 run `npx prisma generate` 
// Step: 2 run `npx prisma migrate dev` after update, make sure code is updated afterwards

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                          @id @default(uuid())
  name                          String
  email                         String                          @unique
  password                      String
  createdAt                     DateTime                        @default(now())
  jobsApplied                   Job[]
  JobTitle                      JobTitle[]
  Location                      Location[]
  Company                       Company[]
  JobSource                     JobSource[]
  Contact                       Contact[]
  Profile                       Profile[]
  Activity                      Activity[]
  ActivityType                  ActivityType[]
  Task                          Task[]
  Automation                    Automation[]
  Settings                      UserSettings?
  ApiKey                        ApiKey[]
  Note                          Note[]
  Tag                           Tag[]
  Question                      Question[]
  // CAREERFLOW: back-relations for Gmail integration (Phase 1).
  OAuthToken                    OAuthToken[]
  EmailThread                   EmailThread[]
  EmailClassificationCorrection EmailClassificationCorrection[]
  // CAREERFLOW: back-relations for Phase 2 (JD eval + reply drafts + usage audit).
  AiDraft                       AiDraft[]
  AiAuditLog                    AiAuditLog[]
}

model ApiKey {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  provider     String
  encryptedKey String
  iv           String
  last4        String
  label        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastUsedAt   DateTime?

  @@unique([userId, provider])
  @@index([userId])
}

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  resumes      Resume[]
  coverLetters CoverLetter[]
}

model Resume {
  id             String          @id @default(uuid())
  profileId      String
  title          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ContactInfo    ContactInfo?
  ResumeSections ResumeSection[]
  profile        Profile         @relation(fields: [profileId], references: [id])
  File           File?           @relation(fields: [FileId], references: [id])
  FileId         String?         @unique
  Job            Job[]
  Automation     Automation[]
}

model CoverLetter {
  id        String   @id @default(uuid())
  profileId String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id])
  Job       Job[]
}

model File {
  id         String   @id @default(uuid())
  fileName   String
  filePath   String
  fileType   String
  uploadedAt DateTime @default(now())
  Resume     Resume?
}

model ResumeSection {
  id                      String                   @id @default(uuid())
  resumeId                String
  sectionTitle            String
  sectionType             String
  summaryId               String?                  @unique
  summary                 Summary?                 @relation(fields: [summaryId], references: [id])
  workExperiences         WorkExperience[]
  educations              Education[]
  licenseOrCertifications LicenseOrCertification[]
  others                  OtherSection[]
  Resume                  Resume                   @relation(fields: [resumeId], references: [id])
}

model ContactInfo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resumeId  String   @unique
  firstName String
  lastName  String
  headline  String
  email     String
  phone     String
  address   String?
  resume    Resume   @relation(fields: [resumeId], references: [id])
}

model Summary {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  content       String
  ResumeSection ResumeSection? @relation
}

model WorkExperience {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  companyId       String
  Company         Company        @relation(fields: [companyId], references: [id])
  jobTitleId      String
  jobTitle        JobTitle       @relation(fields: [jobTitleId], references: [id])
  startDate       DateTime
  endDate         DateTime?
  description     String
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id])
  resumeSectionId String?
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])
}

model Education {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  institution     String
  degree          String
  fieldOfStudy    String
  startDate       DateTime
  endDate         DateTime?
  description     String?
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id])
  resumeSectionId String?
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])
}

model LicenseOrCertification {
  id              String         @id @default(uuid())
  title           String
  organization    String
  issueDate       DateTime?
  expirationDate  DateTime?
  credentialUrl   String?
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])
  resumeSectionId String?
}

model OtherSection {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  title           String
  content         String
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])
  resumeSectionId String?
}

model Contact {
  id          String     @id @default(uuid())
  name        String
  email       String
  createdAt   DateTime
  createdBy   String // userId
  user        User       @relation(fields: [createdBy], references: [id])
  Interview   Interview? @relation(fields: [interviewId], references: [id])
  interviewId String?
}

model JobTitle {
  id              String           @id @default(uuid())
  label           String
  value           String
  jobs            Job[]
  createdBy       String // userId
  user            User             @relation(fields: [createdBy], references: [id])
  workExperiences WorkExperience[]

  @@unique([value, createdBy])
}

model JobStatus {
  id    String @id @default(uuid())
  label String
  value String @unique
  jobs  Job[]
}

model Location {
  id             String           @id @default(uuid())
  label          String
  value          String
  stateProv      String?
  country        String?
  jobsApplied    Job[]
  createdBy      String // userId
  user           User             @relation(fields: [createdBy], references: [id])
  educations     Education[]
  workExperience WorkExperience[]

  @@unique([value, createdBy])
}

model Company {
  id              String           @id @default(uuid())
  label           String
  value           String
  jobsApplied     Job[]
  logoUrl         String? // field is optional
  createdBy       String // userId
  user            User             @relation(fields: [createdBy], references: [id])
  workExperiences WorkExperience[]

  @@unique([value, createdBy])
}

model JobSource {
  id          String @id @default(uuid())
  label       String
  value       String
  jobsApplied Job[]
  createdBy   String // userId
  user        User   @relation(fields: [createdBy], references: [id])

  @@unique([value, createdBy])
}

model Interview {
  id           String    @id @default(uuid())
  createdAt    DateTime
  jobId        String
  job          Job?      @relation(fields: [jobId], references: [id])
  interviewers Contact[]
}

model Job {
  id            String       @id @default(uuid())
  userId        String
  User          User         @relation(fields: [userId], references: [id])
  jobUrl        String?
  description   String
  jobType       String
  createdAt     DateTime
  applied       Boolean      @default(false)
  appliedDate   DateTime?
  dueDate       DateTime?
  statusId      String
  Status        JobStatus    @relation(fields: [statusId], references: [id])
  JobTitle      JobTitle     @relation(fields: [jobTitleId], references: [id])
  jobTitleId    String
  Company       Company      @relation(fields: [companyId], references: [id])
  companyId     String
  JobSource     JobSource?   @relation(fields: [jobSourceId], references: [id])
  jobSourceId   String?
  salaryRange   String?
  Location      Location?    @relation(fields: [locationId], references: [id])
  locationId    String?
  Interview     Interview[]
  Resume        Resume?      @relation(fields: [resumeId], references: [id])
  resumeId      String?
  CoverLetter   CoverLetter? @relation(fields: [coverLetterId], references: [id])
  coverLetterId String?
  Notes         Note[]
  tags          Tag[]

  // Automation discovery fields
  automationId    String?
  automation      Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  matchScore      Int?
  matchData       String?
  discoveryStatus String?
  discoveredAt    DateTime?

  // CAREERFLOW: back-relation to Gmail email threads linked to this Job (Phase 1).
  EmailThread EmailThread[]

  // CAREERFLOW: Phase 2 — JD evaluation result persistence. evaluationJson holds
  // the full JdEvaluationSchema payload as a JSON-encoded string (SQLite has no
  // native JSON). evaluationGrade is denormalized for cheap filtering/listing.
  evaluationGrade String?
  evaluationJson  String?
  evaluatedAt     DateTime?

  // CAREERFLOW: Phase 2 — AI-generated reply drafts linked to this Job.
  AiDraft AiDraft[]

  @@index([userId, automationId])
  @@index([userId, discoveryStatus])
}

model ActivityType {
  id          String   @id @default(uuid())
  label       String
  value       String
  description String?
  createdBy   String // userId
  user        User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Activities Activity[]
  Tasks      Task[]

  @@unique([value, createdBy])
}

model Activity {
  id           String    @id @default(uuid())
  userId       String
  User         User      @relation(fields: [userId], references: [id])
  activityName String
  startTime    DateTime
  endTime      DateTime?
  duration     Int?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityType   ActivityType @relation(fields: [activityTypeId], references: [id])
  activityTypeId String

  taskId String? @unique
  task   Task?   @relation(fields: [taskId], references: [id])
}

model Task {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title           String
  description     String?
  status          String    @default("in-progress")
  priority        Int       @default(5)
  percentComplete Int       @default(0)
  dueDate         DateTime?

  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])

  activity Activity?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, activityTypeId])
  @@index([userId, dueDate])
}

model Automation {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name           String
  jobBoard       String
  keywords       String
  location       String
  resumeId       String
  resume         Resume @relation(fields: [resumeId], references: [id])
  matchThreshold Int    @default(80)

  scheduleHour Int
  nextRunAt    DateTime?
  lastRunAt    DateTime?

  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs           AutomationRun[]
  discoveredJobs Job[]

  @@index([userId])
  @@index([status, nextRunAt])
}

model AutomationRun {
  id           String     @id @default(uuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  jobsSearched     Int @default(0)
  jobsDeduplicated Int @default(0)
  jobsProcessed    Int @default(0)
  jobsMatched      Int @default(0)
  jobsSaved        Int @default(0)

  status        String  @default("running")
  errorMessage  String?
  blockedReason String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([automationId])
  @@index([startedAt])
}

model Note {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([userId])
}

model Tag {
  id        String     @id @default(uuid())
  label     String
  value     String
  createdBy String
  user      User       @relation(fields: [createdBy], references: [id])
  jobs      Job[]
  questions Question[]

  @@unique([value, createdBy])
}

model Question {
  id        String   @id @default(uuid())
  question  String
  answer    String?
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
}

// ---------------------------------------------------------------------------
// CAREERFLOW: Gmail integration models (Phase 1).
//
// Three new models, all FK'd to User and isolated from JobSync's existing
// tables. Encryption pattern mirrors ApiKey: ciphertext column + IV column,
// AES-256-GCM via src/lib/encryption.ts.
// ---------------------------------------------------------------------------

// CAREERFLOW: OAuth refresh + access tokens for the Gmail integration. One row
// per (user, provider) pair; `provider="google"` for Gmail today. Encrypted
// refresh token is required; encrypted access token is cached opportunistically
// to avoid an extra token-exchange call on every poll cycle, and re-derived
// when accessTokenExpiresAt has passed.
model OAuthToken {
  id                    String    @id @default(uuid())
  userId                String
  User                  User      @relation(fields: [userId], references: [id])
  provider              String // "google" today; future: "microsoft" for Outlook
  encryptedRefreshToken String // AES-256-GCM ciphertext (base64) via src/lib/encryption.ts
  refreshTokenIv        String // salt.iv (base64.base64) — same format as ApiKey.iv
  encryptedAccessToken  String? // optional cached access token
  accessTokenIv         String?
  accessTokenExpiresAt  DateTime?
  scope                 String // e.g. "https://www.googleapis.com/auth/gmail.readonly"
  email                 String // the Google account address; shown in Settings → Integrations
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastUsedAt            DateTime?

  @@unique([userId, provider])
  @@index([userId])
}

// CAREERFLOW: cached classification result for a Gmail thread. One row per
// (user, gmailThreadId). `label` / `confidence` come from the HuggingFace
// Space classifier; `needsReview` is true when confidence < the user's
// configured threshold (default 0.7). Optional FK to Job is populated when
// the classifier extracts company + role and we auto-create or auto-link
// a Job record.
model EmailThread {
  id             String  @id @default(uuid())
  userId         String
  User           User    @relation(fields: [userId], references: [id])
  gmailThreadId  String
  gmailMessageId String // most recent message.id in the thread; for direct linking
  jobId          String?
  Job            Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Classification result from the HuggingFace Space classifier.
  label       String // "Applied" | "Interview" | "Rejected" | "Offer" | "NextPhase" | "NotJobRelated"
  confidence  Float
  needsReview Boolean @default(false)

  // Extracted fields (the Space returns these alongside label).
  extractedCompany String?
  extractedRole    String?

  // Email metadata; body intentionally NOT stored by default (PRD §13 privacy).
  subject     String
  snippet     String
  fromAddress String
  receivedAt  DateTime
  processedAt DateTime @default(now())

  Correction EmailClassificationCorrection?

  // CAREERFLOW: Phase 2 — AI-generated reply drafts associated with this thread.
  AiDraft AiDraft[]

  @@unique([userId, gmailThreadId])
  @@index([userId, receivedAt])
  @@index([userId, needsReview])
  @@index([jobId])
}

// CAREERFLOW: captures user corrections when the classifier is wrong. Feeds
// PRD §18 accuracy metric and (in a later phase) a fine-tuning dataset.
// Cascades on EmailThread delete so a thread purge doesn't leave orphans.
model EmailClassificationCorrection {
  id                 String      @id @default(uuid())
  userId             String
  User               User        @relation(fields: [userId], references: [id])
  emailThreadId      String      @unique
  EmailThread        EmailThread @relation(fields: [emailThreadId], references: [id], onDelete: Cascade)
  originalLabel      String
  correctedLabel     String
  originalConfidence Float?
  correctedAt        DateTime    @default(now())

  @@index([userId, correctedAt])
}

// ---------------------------------------------------------------------------
// CAREERFLOW: Phase 2 — JD evaluation, reply drafts, and AI usage audit.
//
// AiDraft persists AI-generated reply suggestions per Gmail thread (and
// optionally per Job). Never sent autonomously — the UI exposes Copy +
// mailto only (PRD §9.5 hard constraint).
//
// AiAuditLog records every paid AI call so the user can see what they're
// spending in Settings → Usage. Powers PRD R6 mitigation.
// ---------------------------------------------------------------------------
model AiDraft {
  id            String       @id @default(uuid())
  userId        String
  User          User         @relation(fields: [userId], references: [id])
  emailThreadId String?
  EmailThread   EmailThread? @relation(fields: [emailThreadId], references: [id], onDelete: SetNull)
  jobId         String?
  Job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  draftType     String // "reply" | "follow-up" | "thank-you" | "confirm"
  subject       String?
  content       String
  tone          String?
  createdAt     DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([emailThreadId])
  @@index([jobId])
}

model AiAuditLog {
  id               String   @id @default(uuid())
  userId           String
  User             User     @relation(fields: [userId], references: [id])
  feature          String // "evaluate" | "reply-draft"
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  costUsd          Float    @default(0)
  msElapsed        Int      @default(0)
  status           String // "success" | "error"
  errorMessage     String?
  jobId            String?
  emailThreadId    String?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, feature])
}
