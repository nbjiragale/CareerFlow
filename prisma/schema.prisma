// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Step: 1 run `npx prisma generate` 
// Step: 2 run `npx prisma migrate dev` after update, make sure code is updated afterwards

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                          @id @default(uuid())
  name                          String
  email                         String                          @unique
  password                      String
  createdAt                     DateTime                        @default(now())
  jobsApplied                   Job[]
  JobTitle                      JobTitle[]
  Location                      Location[]
  Company                       Company[]
  JobSource                     JobSource[]
  Contact                       Contact[]
  Profile                       Profile[]
  Activity                      Activity[]
  ActivityType                  ActivityType[]
  Task                          Task[]
  Automation                    Automation[]
  Settings                      UserSettings?
  ApiKey                        ApiKey[]
  Note                          Note[]
  Tag                           Tag[]
  Question                      Question[]
  // CAREERFLOW: back-relations for Gmail integration (Phase 1).
  OAuthToken                    OAuthToken[]
  EmailThread                   EmailThread[]
  EmailClassificationCorrection EmailClassificationCorrection[]
  // CAREERFLOW: back-relations for Phase 2 (JD eval + reply drafts + usage audit).
  AiDraft                       AiDraft[]
  AiAuditLog                    AiAuditLog[]
  // CAREERFLOW: back-relations for Phase 3 (reminders + email log).
  Reminder                      Reminder[]
  EmailLog                      EmailLog[]
}

model ApiKey {
  id           String    @id @default(uuid())
  userId       String
  // CAREERFLOW: Phase 3 — cascade so Settings → Delete Account removes encrypted keys.
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  encryptedKey String
  iv           String
  last4        String
  label        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastUsedAt   DateTime?

  @@unique([userId, provider])
  @@index([userId])
}

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  // CAREERFLOW: Phase 3 — cascade so Settings → Delete Account removes user prefs.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id           String        @id @default(uuid())
  userId       String
  // CAREERFLOW: Phase 3 — cascade so Settings → Delete Account removes Profile chain.
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes      Resume[]
  coverLetters CoverLetter[]
}

model Resume {
  id             String          @id @default(uuid())
  profileId      String
  title          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ContactInfo    ContactInfo?
  ResumeSections ResumeSection[]
  // CAREERFLOW: Phase 3 — cascade so Profile delete (in turn cascaded from User) wipes Resume.
  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  File           File?           @relation(fields: [FileId], references: [id])
  FileId         String?         @unique
  Job            Job[]
  Automation     Automation[]
}

model CoverLetter {
  id        String   @id @default(uuid())
  profileId String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // CAREERFLOW: Phase 3 — cascade so Profile delete wipes CoverLetter.
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  Job       Job[]
}

model File {
  id         String   @id @default(uuid())
  fileName   String
  filePath   String
  fileType   String
  uploadedAt DateTime @default(now())
  Resume     Resume?
}

model ResumeSection {
  id                      String                   @id @default(uuid())
  resumeId                String
  sectionTitle            String
  sectionType             String
  summaryId               String?                  @unique
  // CAREERFLOW: Phase 3 — SetNull on optional Summary so cascade from Resume
  // doesn't break when a section has no summary attached.
  summary                 Summary?                 @relation(fields: [summaryId], references: [id], onDelete: SetNull)
  workExperiences         WorkExperience[]
  educations              Education[]
  licenseOrCertifications LicenseOrCertification[]
  others                  OtherSection[]
  // CAREERFLOW: Phase 3 — cascade so Resume delete wipes ResumeSection.
  Resume                  Resume                   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ContactInfo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resumeId  String   @unique
  firstName String
  lastName  String
  headline  String
  email     String
  phone     String
  address   String?
  // CAREERFLOW: Phase 3 — cascade so Resume delete wipes ContactInfo.
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Summary {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  content       String
  ResumeSection ResumeSection? @relation
}

model WorkExperience {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  companyId       String
  // CAREERFLOW: Phase 3 — cascade so deleting a user-owned Company removes their WorkExperiences.
  Company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobTitleId      String
  // CAREERFLOW: Phase 3 — cascade so deleting a user-owned JobTitle removes their WorkExperiences.
  jobTitle        JobTitle       @relation(fields: [jobTitleId], references: [id], onDelete: Cascade)
  startDate       DateTime
  endDate         DateTime?
  description     String
  locationId      String
  // CAREERFLOW: Phase 3 — cascade so deleting a user-owned Location removes their WorkExperiences.
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  resumeSectionId String?
  // CAREERFLOW: Phase 3 — SetNull so ResumeSection delete just unlinks (already cascaded via owner).
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id], onDelete: SetNull)
}

model Education {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  institution     String
  degree          String
  fieldOfStudy    String
  startDate       DateTime
  endDate         DateTime?
  description     String?
  locationId      String
  // CAREERFLOW: Phase 3 — cascade so Location delete (via User cascade) removes the Education row.
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  resumeSectionId String?
  // CAREERFLOW: Phase 3 — SetNull so ResumeSection delete just unlinks.
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id], onDelete: SetNull)
}

model LicenseOrCertification {
  id              String         @id @default(uuid())
  title           String
  organization    String
  issueDate       DateTime?
  expirationDate  DateTime?
  credentialUrl   String?
  // CAREERFLOW: Phase 3 — SetNull so ResumeSection delete just unlinks.
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id], onDelete: SetNull)
  resumeSectionId String?
}

model OtherSection {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  title           String
  content         String
  // CAREERFLOW: Phase 3 — SetNull so ResumeSection delete just unlinks.
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id], onDelete: SetNull)
  resumeSectionId String?
}

model Contact {
  id          String     @id @default(uuid())
  name        String
  email       String
  createdAt   DateTime
  createdBy   String // userId
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their contacts.
  user        User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  // CAREERFLOW: Phase 3 — SetNull so Interview delete just unlinks (Contact survives).
  Interview   Interview? @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  interviewId String?
}

model JobTitle {
  id              String           @id @default(uuid())
  label           String
  value           String
  jobs            Job[]
  createdBy       String // userId
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their JobTitle lookups.
  user            User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  workExperiences WorkExperience[]

  @@unique([value, createdBy])
}

model JobStatus {
  id    String @id @default(uuid())
  label String
  value String @unique
  jobs  Job[]
}

model Location {
  id             String           @id @default(uuid())
  label          String
  value          String
  stateProv      String?
  country        String?
  jobsApplied    Job[]
  createdBy      String // userId
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Location lookups.
  user           User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  educations     Education[]
  workExperience WorkExperience[]

  @@unique([value, createdBy])
}

model Company {
  id              String           @id @default(uuid())
  label           String
  value           String
  jobsApplied     Job[]
  logoUrl         String? // field is optional
  createdBy       String // userId
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Company lookups.
  user            User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  workExperiences WorkExperience[]

  @@unique([value, createdBy])
}

model JobSource {
  id          String @id @default(uuid())
  label       String
  value       String
  jobsApplied Job[]
  createdBy   String // userId
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their JobSource lookups.
  user        User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([value, createdBy])
}

model Interview {
  id           String    @id @default(uuid())
  createdAt    DateTime
  jobId        String
  // CAREERFLOW: Phase 3 — cascade so Job delete wipes its Interview rows.
  job          Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviewers Contact[]
}

model Job {
  id            String       @id @default(uuid())
  userId        String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Jobs (→ Notes, Interviews, drafts).
  User          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobUrl        String?
  description   String
  jobType       String
  createdAt     DateTime
  applied       Boolean      @default(false)
  appliedDate   DateTime?
  dueDate       DateTime?
  statusId      String
  // JobStatus is a global lookup (not user-owned); no cascade.
  Status        JobStatus    @relation(fields: [statusId], references: [id])
  // CAREERFLOW: Phase 3 — cascade because JobTitle is user-owned and cascades from User.
  JobTitle      JobTitle     @relation(fields: [jobTitleId], references: [id], onDelete: Cascade)
  jobTitleId    String
  // CAREERFLOW: Phase 3 — cascade because Company is user-owned and cascades from User.
  Company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String
  // CAREERFLOW: Phase 3 — SetNull on optional lookup FKs so deletes don't error mid-walk.
  JobSource     JobSource?   @relation(fields: [jobSourceId], references: [id], onDelete: SetNull)
  jobSourceId   String?
  salaryRange   String?
  Location      Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId    String?
  Interview     Interview[]
  Resume        Resume?      @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  resumeId      String?
  CoverLetter   CoverLetter? @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)
  coverLetterId String?
  Notes         Note[]
  tags          Tag[]

  // Automation discovery fields
  automationId    String?
  automation      Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  matchScore      Int?
  matchData       String?
  discoveryStatus String?
  discoveredAt    DateTime?

  // CAREERFLOW: back-relation to Gmail email threads linked to this Job (Phase 1).
  EmailThread EmailThread[]

  // CAREERFLOW: Phase 2 — JD evaluation result persistence. evaluationJson holds
  // the full JdEvaluationSchema payload as a JSON-encoded string (SQLite has no
  // native JSON). evaluationGrade is denormalized for cheap filtering/listing.
  evaluationGrade String?
  evaluationJson  String?
  evaluatedAt     DateTime?

  // CAREERFLOW: Interview Copilot — cached prep brief (InterviewPrepSchema as a
  // JSON-encoded string) generated on demand for interview-stage jobs.
  interviewPrepJson  String?
  interviewPreppedAt DateTime?

  // CAREERFLOW: Phase 2 — AI-generated reply drafts linked to this Job.
  AiDraft AiDraft[]

  @@index([userId, automationId])
  @@index([userId, discoveryStatus])
}

model ActivityType {
  id          String   @id @default(uuid())
  label       String
  value       String
  description String?
  createdBy   String // userId
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their ActivityType lookups.
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Activities Activity[]
  Tasks      Task[]

  @@unique([value, createdBy])
}

model Activity {
  id           String    @id @default(uuid())
  userId       String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Activity rows.
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityName String
  startTime    DateTime
  endTime      DateTime?
  duration     Int?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // CAREERFLOW: Phase 3 — unified timeline source tag. "manual" for hand-entered
  // rows, "gmail" / "ai_eval" / "ai_match" / "ai_draft" / "scheduler" for
  // system-generated events. Default keeps backfill simple.
  source       String  @default("manual")
  // CAREERFLOW: Phase 3 — JSON-encoded extra fields per source (e.g. emailThreadId,
  // aiDraftId). SQLite has no native JSON; we store a String and parse on read.
  metadataJson String?

  // CAREERFLOW: Phase 3 — cascade so the ActivityType lookup row going away
  // (which itself cascades from User) takes the Activity with it.
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  activityTypeId String

  taskId String? @unique
  // CAREERFLOW: Phase 3 — SetNull on optional Task FK so Task delete just unlinks.
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, source, startTime])
}

model Task {
  id     String @id @default(uuid())
  userId String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Tasks.
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  status          String    @default("in-progress")
  priority        Int       @default(5)
  percentComplete Int       @default(0)
  dueDate         DateTime?

  // CAREERFLOW: Phase 3 — reminder scheduling. remindAt is when to fire (may differ
  // from dueDate). remindedAt is stamped once the dispatcher fires so the same
  // reminder doesn't double-trigger. remindChannels is a JSON array of
  // "browser" | "email" — default keeps the noisy email channel opt-in.
  remindAt       DateTime?
  remindedAt     DateTime?
  remindChannels String    @default("[\"browser\"]")

  activityTypeId String?
  // CAREERFLOW: Phase 3 — SetNull on optional ActivityType FK.
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)

  activity Activity?
  // CAREERFLOW: Phase 3 — back-relation for outbound notifications.
  Reminder Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, activityTypeId])
  @@index([userId, dueDate])
  // CAREERFLOW: Phase 3 — covers the dispatcher's "due and not yet sent" query.
  @@index([remindAt, remindedAt])
}

model Automation {
  id     String @id @default(uuid())
  userId String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Automations.
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  jobBoard       String
  keywords       String
  location       String
  resumeId       String
  // CAREERFLOW: Phase 3 — cascade so Resume delete (via User chain) wipes Automation.
  resume         Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  matchThreshold Int    @default(80)

  scheduleHour Int
  nextRunAt    DateTime?
  lastRunAt    DateTime?

  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs           AutomationRun[]
  discoveredJobs Job[]

  @@index([userId])
  @@index([status, nextRunAt])
}

model AutomationRun {
  id           String     @id @default(uuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  jobsSearched     Int @default(0)
  jobsDeduplicated Int @default(0)
  jobsProcessed    Int @default(0)
  jobsMatched      Int @default(0)
  jobsSaved        Int @default(0)

  status        String  @default("running")
  errorMessage  String?
  blockedReason String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([automationId])
  @@index([startedAt])
}

model Note {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Notes.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([userId])
}

model Tag {
  id        String     @id @default(uuid())
  label     String
  value     String
  createdBy String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Tags.
  user      User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  jobs      Job[]
  questions Question[]

  @@unique([value, createdBy])
}

model Question {
  id        String   @id @default(uuid())
  question  String
  answer    String?
  createdBy String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their Questions.
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
}

// ---------------------------------------------------------------------------
// CAREERFLOW: Gmail integration models (Phase 1).
//
// Three new models, all FK'd to User and isolated from JobSync's existing
// tables. Encryption pattern mirrors ApiKey: ciphertext column + IV column,
// AES-256-GCM via src/lib/encryption.ts.
// ---------------------------------------------------------------------------

// CAREERFLOW: OAuth refresh + access tokens for the Gmail integration. One row
// per (user, provider) pair; `provider="google"` for Gmail today. Encrypted
// refresh token is required; encrypted access token is cached opportunistically
// to avoid an extra token-exchange call on every poll cycle, and re-derived
// when accessTokenExpiresAt has passed.
model OAuthToken {
  id                    String    @id @default(uuid())
  userId                String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes encrypted Gmail tokens.
  User                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              String // "google" today; future: "microsoft" for Outlook
  encryptedRefreshToken String // AES-256-GCM ciphertext (base64) via src/lib/encryption.ts
  refreshTokenIv        String // salt.iv (base64.base64) — same format as ApiKey.iv
  encryptedAccessToken  String? // optional cached access token
  accessTokenIv         String?
  accessTokenExpiresAt  DateTime?
  scope                 String // e.g. "https://www.googleapis.com/auth/gmail.readonly"
  email                 String // the Google account address; shown in Settings → Integrations
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastUsedAt            DateTime?

  @@unique([userId, provider])
  @@index([userId])
}

// CAREERFLOW: cached classification result for a Gmail thread. One row per
// (user, gmailThreadId). `label` / `confidence` come from the HuggingFace
// Space classifier; `needsReview` is true when confidence < the user's
// configured threshold (default 0.7). Optional FK to Job is populated when
// the classifier extracts company + role and we auto-create or auto-link
// a Job record.
model EmailThread {
  id             String  @id @default(uuid())
  userId         String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their EmailThreads.
  User           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailThreadId  String
  gmailMessageId String // most recent message.id in the thread; for direct linking
  jobId          String?
  Job            Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Classification result from the HuggingFace Space classifier.
  label       String // "Applied" | "Interview" | "Rejected" | "Offer" | "NextPhase" | "NotJobRelated"
  confidence  Float
  needsReview Boolean @default(false)
  // CAREERFLOW: once the user applies or dismisses the status change this
  // thread's classification implies, we stop surfacing it as a suggestion.
  statusSuggestionHandled Boolean @default(false)

  // Extracted fields (the Space returns these alongside label).
  extractedCompany String?
  extractedRole    String?

  // Email metadata; body intentionally NOT stored by default (PRD §13 privacy).
  subject     String
  snippet     String
  fromAddress String
  receivedAt  DateTime
  processedAt DateTime @default(now())

  Correction EmailClassificationCorrection?

  // CAREERFLOW: Phase 2 — AI-generated reply drafts associated with this thread.
  AiDraft AiDraft[]

  @@unique([userId, gmailThreadId])
  @@index([userId, receivedAt])
  @@index([userId, needsReview])
  @@index([jobId])
}

// CAREERFLOW: captures user corrections when the classifier is wrong. Feeds
// PRD §18 accuracy metric and (in a later phase) a fine-tuning dataset.
// Cascades on EmailThread delete so a thread purge doesn't leave orphans.
model EmailClassificationCorrection {
  id                 String      @id @default(uuid())
  userId             String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their corrections.
  User               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailThreadId      String      @unique
  EmailThread        EmailThread @relation(fields: [emailThreadId], references: [id], onDelete: Cascade)
  originalLabel      String
  correctedLabel     String
  originalConfidence Float?
  correctedAt        DateTime    @default(now())

  @@index([userId, correctedAt])
}

// ---------------------------------------------------------------------------
// CAREERFLOW: Phase 2 — JD evaluation, reply drafts, and AI usage audit.
//
// AiDraft persists AI-generated reply suggestions per Gmail thread (and
// optionally per Job). Never sent autonomously — the UI exposes Copy +
// mailto only (PRD §9.5 hard constraint).
//
// AiAuditLog records every paid AI call so the user can see what they're
// spending in Settings → Usage. Powers PRD R6 mitigation.
// ---------------------------------------------------------------------------
model AiDraft {
  id            String       @id @default(uuid())
  userId        String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their AI drafts.
  User          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailThreadId String?
  EmailThread   EmailThread? @relation(fields: [emailThreadId], references: [id], onDelete: SetNull)
  jobId         String?
  Job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  draftType     String // "reply" | "follow-up" | "thank-you" | "confirm"
  subject       String?
  content       String
  tone          String?
  createdAt     DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([emailThreadId])
  @@index([jobId])
}

model AiAuditLog {
  id               String   @id @default(uuid())
  userId           String
  // CAREERFLOW: Phase 3 — cascade so user deletion removes their AI audit log rows.
  User             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature          String // "evaluate" | "reply-draft"
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  costUsd          Float    @default(0)
  msElapsed        Int      @default(0)
  status           String // "success" | "error"
  errorMessage     String?
  jobId            String?
  emailThreadId    String?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, feature])
}

// ---------------------------------------------------------------------------
// CAREERFLOW: Phase 3 — reminders + outbound email audit.
//
// Reminder: one row per (Task, channel) dispatch attempt. Written by the
// 1-minute scheduler tick (`src/lib/scheduler/index.ts`) when a Task's
// remindAt has elapsed and remindedAt is still null. Browser deliveries
// are streamed to the dashboard via SSE; email deliveries call the
// optional nodemailer transport.
//
// EmailLog: audit-only history of outbound emails. Powers a future
// "what got sent" view in Settings without keeping the recipient address
// in memory. Cascades from User per the Phase 3 hard-delete contract.
// ---------------------------------------------------------------------------
model Reminder {
  id           String    @id @default(uuid())
  userId       String
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId       String
  Task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  channel      String // "browser" | "email"
  payloadJson  String // JSON-encoded notification payload (title, body, link)
  status       String    @default("pending") // "pending" | "sent" | "failed"
  errorMessage String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?

  @@index([userId, status])
  @@index([taskId])
  @@index([status, createdAt])
}

model EmailLog {
  id           String   @id @default(uuid())
  userId       String
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toAddress    String
  subject      String
  template     String // "task-reminder" etc.
  status       String // "sent" | "failed"
  errorMessage String?
  sentAt       DateTime @default(now())

  @@index([userId, sentAt])
}
