# Note: Copy this file to .env (`cp .env.example .env`) and fill in values as needed.
#
# Two dev tracks are supported:
#   1. Active dev (no Docker): `npm run dev` — uses the DATABASE_URL set below.
#   2. Self-host / deploy (Docker): `docker compose up` — docker-compose.yml overrides
#      DATABASE_URL to /data/dev.db inside the container; .env is NOT used by compose.

# Local SQLite path for `npm run dev`. The `file:` prefix is required by Prisma
# and the path is resolved relative to the `prisma/` directory (where
# schema.prisma lives), so `file:./dev.db` produces `./prisma/dev.db`.
DATABASE_URL=file:./dev.db

# If you are running it on a remote server/homelab, you must update timezone otherwise activities times may shift
TZ=America/Edmonton

# For homelab server, change the following to your server ip ex: http://192.168.x.x:3737
NEXTAUTH_URL=http://localhost:3737

# AUTH_SECRET is auto-generated by deploy.sh and docker-entrypoint.sh.
# For local dev, generate one and paste it here.
# Generate with: openssl rand -base64 32
# AUTH_SECRET=

# ENCRYPTION_KEY is used to encrypt stored API keys (OpenAI, DeepSeek, RapidAPI, etc.)
# Must be stable across restarts — changing it will make all stored API keys unrecoverable.
# Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=

OPENAI_API_KEY=your-openai-api-key-here

# DeepSeek API Key - get from https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Google Gemini API Key - get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# For homelab server, if you ollama is running on server, change the following to your ollamma ip ex: http://192.168.x.x:12345
OLLAMA_BASE_URL=http://host.docker.internal:11434

# AI Configuration
# The system uses LLM-based semantic extraction for intelligent, context-aware skill matching
# No configuration needed - semantic extraction is the default

RAPIDAPI_KEY=your-rapidapi-key-here

# ---------------------------------------------------------------------------
# CareerFlow additions (Phase 1+)
# ---------------------------------------------------------------------------
# Google OAuth credentials for the Gmail integration. Required only once
# Phase 1 lands. Until then these can be left blank.
# Create a project in https://console.cloud.google.com, enable the Gmail API
# (gmail.readonly scope), and configure OAuth credentials with the redirect URI
# below.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3737/api/gmail/callback
